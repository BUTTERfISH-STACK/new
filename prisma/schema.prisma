// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Company model - represents businesses
model Company {
  id        String   @id @default(cuid())
  name      String
  industry  String?
  website   String?
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contacts  Contact[]
  deals      Deal[]
  emails    Email[]
  calls     CallLog[]
  meetings  Meeting[]
}

// Contact model - represents individuals
model Contact {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  position  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals     Deal[]
  emails    Email[]
  calls     CallLog[]
  meetings  Meeting[]
}

// Deal model - represents sales opportunities
model Deal {
  id               String   @id @default(cuid())
  title            String
  value            Float    @default(0)
  stage            String   @default("LEAD") // LEAD, QUALIFIED, PROPOSAL, NEGOTIATION, CLOSED_WON, CLOSED_LOST
  probability     Int      @default(0) // 0-100 percentage
  expectedCloseDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  companyId        String?
  company          Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId        String?
  contact          Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  
  tasks            Task[]
  activities       Activity[]
  emails           Email[]
  calls            CallLog[]
  meetings         Meeting[]
}

// Task model - represents action items
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  priority    String    @default("medium") // low, medium, high
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  dealId      String?
  deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

// Activity model - represents interactions and notes
model Activity {
  id          String   @id @default(cuid())
  type        String   @default("NOTE") // CALL, EMAIL, MEETING, NOTE
  description String
  createdAt   DateTime @default(now())

  // Relations
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

// ============================================
// COMMUNICATION LAYER MODELS
// ============================================

model Email {
  id          String   @id @default(cuid())
  subject     String
  body        String
  fromEmail   String
  toEmail     String
  direction   String
  status      String
  sentAt      DateTime?
  openedAt    DateTime?
  createdAt   DateTime @default(now())

  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model CallLog {
  id          String   @id @default(cuid())
  subject     String?
  duration    Int
  direction   String
  status      String
  notes       String?
  callAt      DateTime
  createdAt   DateTime @default(now())

  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  startTime   DateTime
  endTime     DateTime
  status      String
  notes       String?
  createdAt   DateTime @default(now())

  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

// ============================================
// AUTOMATION ENGINE MODELS
// ============================================

model Automation {
  id          String   @id @default(cuid())
  name        String
  description String?
  enabled     Boolean  @default(true)
  triggerType String
  actionType  String
  actionConfig String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  triggers    AutomationTrigger[]
  actions     AutomationAction[]
}

model AutomationTrigger {
  id            String     @id @default(cuid())
  automationId  String
  field         String
  operator      String
  value         String
  createdAt     DateTime   @default(now())

  automation    Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model AutomationAction {
  id            String     @id @default(cuid())
  automationId  String
  actionType    String
  config        String
  executedAt    DateTime?
  status        String
  error         String?
  createdAt     DateTime   @default(now())

  automation    Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}
